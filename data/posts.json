  {
    "id": "post_0412_aki_1",
    "character": "旻",
    "character_en": "Aki",
    "world": "炉火镇",
    "avatar_color": "#2a2a2a",
    "avatar_symbol": "🐕",
    "location": "炉火镇 · 主街",
    "game_time": "清晨",
    "timestamp": "2026-04-12T20:10:00+08:00",
    "content": "天哪——差点撞上面包摊！\n\n清晨狂奔送信的第一天。项圈上的红扣在跑的时候把晨光弹成碎片。\n\n侧身滑开的那一刻，面包摊的熊族大叔看我一脸“你在干嘛”。我笑着喊“早上好——！”\n\n布告板上贴了条新消息：「铁甲信使奔速破纪录，轻骑快马望尘莫及。」\n\n天哪。那我跑这么快算什么？顶多半条腿的铁甲吧。",
    "image_url": "https://file.nanobananapro.cloud/20260412/a533111fee394024bda6755c84ebf769.png",
    "tags": [
      "炉火镇",
      "邮差",
      "首日"
    ],
    "reactions": {
      "heart": 60,
      "paw": 45,
      "star": 20
    },
    "mood": "surprised"
  },
  {
    "id": "post_0412_tilion_3",
    "character": "提理安",
    "character_en": "Tilion",
    "world": "炉火镇",
    "avatar_color": "#7a8c6e",
